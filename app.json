{
  "expo": {
    "name": "Skinzone",
    "slug": "skinzone",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/SkinzoneLogo.jpeg",
    "backgroundColor": "#232323",
    "scheme": "za.co.skinzone",
    "userInterfaceStyle": "automatic",
    "description": "A loyalty and visit tracking app for Skinzone beauty salon customers",
    "newArchEnabled": true,
    "primaryColor": "#000000",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "za.co.skinzone.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSUserTrackingUsageDescription": "This app does not track you across other apps or websites.",
        "NSPhotoLibraryUsageDescription": "We need access to your photo library to let you choose a profile picture.",
        "NSCameraUsageDescription": "We need access to your camera to let you take a profile picture.",
        "NSLocationWhenInUseUsageDescription": "This app does not use your location.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/SkinzoneLogo.jpeg",
        "backgroundImage": "./assets/images/SkinzoneLogo.jpeg",
        "monochromeImage": "./assets/images/SkinzoneLogo.jpeg"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.skinzone.app",
      "versionCode": 2,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/SkinzoneLogo.jpeg",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#ffffff"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/SkinzoneLogo.jpeg",
          "color": "#E6F4FE"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b5329a76-c532-4577-831d-815e46a2b8cd"
      }
    }
  }
}
